# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data — raw MovieLens files are large; processed data is reproducible
data/raw/
data/processed/

# Model artifacts — regenerated by training scripts
artifacts/models/
artifacts/embeddings/

# Exception: commit evaluation metric JSON so the frontend/insights page works
# without retraining (artifacts/metrics/ is NOT ignored)
!artifacts/metrics/

# Environment variables
.env
.env.local
.env.*.local

# Node / frontend
frontend/node_modules/
frontend/.next/
frontend/build/
frontend/dist/
frontend/.env.local

# OS
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Reports — keep generated plots out of git; the notebooks reproduce them
reports/evaluation/*.png
reports/evaluation/*.svg
reports/evaluation/*.pdf
